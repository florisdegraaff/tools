# Core app
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Prisma)
# Example: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DATABASE_URL=

# Optional: direct/admin database URL for migrations or pooling setups
# DIRECT_URL=

# Optional: Sanity CMS (only required if Sanity is used)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: analytics or external APIs
# NEXT_PUBLIC_ANALYTICS_ID=
# EXTERNAL_API_KEY=
