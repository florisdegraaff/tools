# Plain password the server expects after RSA decryption (POST /api/login).
LOGIN_PASSWORD=

# RSA private key (PEM), server-only — pair with NEXT_PUBLIC_LOGIN_RSA_PUBLIC_KEY.
# Generate (run in repo root, then paste file contents into .env / hosting secrets):
#   openssl genrsa -out login_rsa_private.pem 2048
#   openssl rsa -in login_rsa_private.pem -pubout -out login_rsa_public.pem
# Multi-line PEM in .env: use double quotes and \n for newlines, or a single line PEM.
LOGIN_RSA_PRIVATE_KEY=

# RSA public key (PEM), same modulus as LOGIN_RSA_PRIVATE_KEY — safe to expose to the browser.
NEXT_PUBLIC_LOGIN_RSA_PUBLIC_KEY=
